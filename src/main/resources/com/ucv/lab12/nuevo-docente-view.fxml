<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefWidth="400.0" spacing="15.0" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://fxml.com/fx/1" fx:controller="com.ucv.lab12.controller.NuevoDocenteController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
    <children>
        <Label text="Registrar Nuevo Docente" textFill="#1d3557">
            <font>
                <Font name="System Bold" size="18.0" />
            </font>
        </Label>

        <VBox spacing="5.0">
            <children>
                <Label text="DNI:" />
                <TextField fx:id="txtDni" promptText="Ingrese 8 dígitos" />
            </children>
        </VBox>

        <VBox spacing="5.0">
            <children>
                <Label text="Nombres:" />
                <TextField fx:id="txtNombres" promptText="Nombres del docente" />
            </children>
        </VBox>

        <VBox spacing="5.0">
            <children>
                <Label text="Apellidos:" />
                <TextField fx:id="txtApellidos" promptText="Apellidos del docente" />
            </children>
        </VBox>

        <Button fx:id="btnGuardar" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#guardarDocente" text="Guardar Docente" />
    </children>
</VBox>