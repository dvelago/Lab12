<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.ucv.lab12.controller.VideojuegoController"
      spacing="10"
      style="-fx-padding:15; -fx-background-color:#F5F7FA;">

    <Label text="Compra de Videojuegos"
           style="-fx-font-size:22; -fx-font-weight:bold; -fx-text-fill:#0D47A1;">
        <font><Font size="22.0"/></font>
    </Label>
    <Separator/>

    <HBox spacing="10" alignment="CENTER_LEFT"
          style="-fx-background-color:#E3F2FD; -fx-padding:10; -fx-background-radius:6;">
        <Label text="Nombre:" style="-fx-font-weight:bold;"/>
        <TextField fx:id="txtNombre" promptText="Buscar por nombre" prefWidth="200"/>
        <Label text="Consola:" style="-fx-font-weight:bold;"/>
        <TextField fx:id="txtConsola" promptText="Buscar por consola" prefWidth="160"/>
        <Label text="Genero:" style="-fx-font-weight:bold;"/>
        <TextField fx:id="txtGenero" promptText="Buscar por genero" prefWidth="160"/>
        <Button fx:id="btnBuscar" text="Buscar" onAction="#onBuscar"
                style="-fx-background-color:#1976D2;-fx-text-fill:white;-fx-cursor:hand;-fx-font-weight:bold;"
                prefWidth="90"/>
    </HBox>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Button fx:id="btnNuevo" text="Nuevo videojuego" onAction="#onNuevo"
                style="-fx-background-color:#2E7D32;-fx-text-fill:white;-fx-cursor:hand;-fx-font-weight:bold;"
                prefWidth="150"/>
        <Button fx:id="btnRecargar" text="Recargar" onAction="#onRecargar"
                style="-fx-background-color:#455A64;-fx-text-fill:white;-fx-cursor:hand;-fx-font-weight:bold;"
                prefWidth="110"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="lblTotal" text="Total: 0 videojuego(s)"
               style="-fx-font-style:italic; -fx-text-fill:#555;"/>
    </HBox>

    <TableView fx:id="tableView" VBox.vgrow="ALWAYS"
               style="-fx-background-color:white; -fx-border-color:#CFD8DC; -fx-border-radius:4;">
        <columns>
            <TableColumn fx:id="colId" text="ID" prefWidth="60"/>
            <TableColumn fx:id="colNombre" text="Nombre" prefWidth="180"/>
            <TableColumn fx:id="colConsola" text="Consola" prefWidth="110"/>
            <TableColumn fx:id="colGenero" text="Genero" prefWidth="120"/>
            <TableColumn fx:id="colClasificacion" text="Clasificacion" prefWidth="120"/>
            <TableColumn fx:id="colDesarrollador" text="Desarrollador ID" prefWidth="120"/>
            <TableColumn fx:id="colDistribuidor" text="Distribuidor ID" prefWidth="120"/>
            <TableColumn fx:id="colPrecio" text="Precio" prefWidth="100"/>
            <TableColumn fx:id="colStock" text="Stock" prefWidth="80"/>
            <TableColumn fx:id="colAcciones" text="Acciones" prefWidth="235"/>
        </columns>
        <placeholder>
            <Label text="No hay videojuegos para mostrar." style="-fx-text-fill:#888;"/>
        </placeholder>
    </TableView>

</VBox>
