<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.ucv.lab12.controller.CompraVideojuegoFormController"
      spacing="10"
      style="-fx-padding:15; -fx-background-color:#FFFFFF; -fx-pref-width:520;">

    <Label text="Compra de videojuego"
           style="-fx-font-size:20; -fx-font-weight:bold; -fx-text-fill:#0D47A1;">
        <font><Font size="20.0"/></font>
    </Label>
    <Separator/>

    <VBox spacing="8">
        <Label text="Videojuego:" style="-fx-font-weight:bold;"/>
        <Label fx:id="lblVideojuego" text="-" style="-fx-text-fill:#37474F;"/>

        <Label text="Precio unitario:" style="-fx-font-weight:bold;"/>
        <Label fx:id="lblPrecioUnitario" text="S/ 0.00" style="-fx-text-fill:#37474F;"/>

        <Label text="Comprador:" style="-fx-font-weight:bold;"/>
        <TextField fx:id="txtComprador" promptText="Nombre del comprador"/>

        <Label text="Correo:" style="-fx-font-weight:bold;"/>
        <TextField fx:id="txtCorreo" promptText="correo@ejemplo.com"/>

        <Label text="Cantidad:" style="-fx-font-weight:bold;"/>
        <Spinner fx:id="spnCantidad" editable="false"/>

        <Label text="Metodo de pago:" style="-fx-font-weight:bold;"/>
        <ComboBox fx:id="cmbMetodoPago" promptText="Seleccione un metodo"/>

        <Label text="Total:" style="-fx-font-weight:bold;"/>
        <Label fx:id="lblTotal" text="S/ 0.00" style="-fx-font-size:16; -fx-text-fill:#2E7D32; -fx-font-weight:bold;"/>
    </VBox>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button fx:id="btnCancelar" text="Cancelar" onAction="#onCancelar"
                style="-fx-background-color:#607D8B;-fx-text-fill:white;-fx-cursor:hand;-fx-font-weight:bold;"
                prefWidth="110"/>
        <Button fx:id="btnComprar" text="Comprar" onAction="#onComprar"
                style="-fx-background-color:#2E7D32;-fx-text-fill:white;-fx-cursor:hand;-fx-font-weight:bold;"
                prefWidth="110"/>
    </HBox>

</VBox>
