<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="15.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.ucv.lab12.controller.LoginController" style="-fx-background-color: #f4f4f4;">
    <padding>
        <Insets bottom="30.0" left="40.0" right="40.0" top="30.0" />
    </padding>
    <children>
        <Label text="UGEL - Iniciar Sesión" textFill="#1a365d">
            <font>
                <Font name="System Bold" size="20.0" />
            </font>
            <VBox.margin>
                <Insets bottom="10.0" />
            </VBox.margin>
        </Label>
        <VBox spacing="5.0">
            <children>
                <Label text="Usuario:" />
                <TextField fx:id="txtUsuario" promptText="Ingrese su usuario" prefWidth="250.0" />
            </children>
        </VBox>
        <VBox spacing="5.0">
            <children>
                <Label text="Contraseña:" />
                <PasswordField fx:id="txtPassword" promptText="Ingrese su contraseña" />
            </children>
        </VBox>
        <Button fx:id="btnLogin" mnemonicParsing="false" onAction="#manejarLogin" text="Ingresar" prefWidth="250.0" style="-fx-background-color: #1a365d; -fx-text-fill: white; -fx-cursor: hand;">
            <font>
                <Font name="System Bold" size="14.0" />
            </font>
            <VBox.margin>
                <Insets top="10.0" />
            </VBox.margin>
        </Button>
    </children>
</VBox>